Z","shell.execute_reply":"2025-02-08T12:09:07.387878Z"}},"outputs":[{"name":"stdout","text":"Unknown characters in test labels: {'H'}\n","output_type":"stream"}],"execution_count":23},{"cell_type":"code","source":"empty_test_labels = test_data[test_data['label'].str.strip() == '']\nprint(f\"Number of empty labels in test data: {len(empty_test_labels)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:09:07.389662Z","iopub.execute_input":"2025-02-08T12:09:07.389993Z","iopub.status.idle":"2025-02-08T12:09:07.408319Z","shell.execute_reply.started":"2025-02-08T12:09:07.389958Z","shell.execute_reply":"2025-02-08T12:09:07.407504Z"}},"outputs":[{"name":"stdout","text":"Number of empty labels in test data: 0\n","output_type":"stream"}],"execution_count":24},{"cell_type":"code","source":"max_label_length_test = max(len(lbl) for lbl in test_data['label']) + 2\n\ndef encode_label_test(label, char_to_idx, max_length):\n    encoded = (\n        [char_to_idx['<SOS>']] +\n        [char_to_idx.get(ch, char_to_idx['<UNK>']) for ch in label] +\n        [char_to_idx['<EOS>']]\n    )\n    # Truncate or pad to max_length\n    if len(encoded) > max_length:\n        encoded = encoded[:max_length]\n    else:\n        encoded += [char_to_idx['<PAD>']] * (max_length - len(encoded))\n    return encoded\n\n# Create encoded_label and label_length columns in test_data\ntest_data['encoded_label'] = test_data['label'].apply(lambda x: encode_label_test(x, char_to_idx, max_label_length_test))\ntest_data['label_length'] = test_data['label'].apply(len)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:09:07.411096Z","iopub.execute_input":"2025-02-08T12:09:07.411412Z","iopub.status.idle":"2025-02-08T12:09:07.447540Z","shell.execute_reply.started":"2025-02-08T12:09:07.411387Z","shell.execute_reply":"2025-02-08T12:09:07.446935Z"}},"outputs":[],"execution_count":25},{"cell_type":"code","source":"test_transform = transforms.Compose([\n    transforms.Resize((64, 256)),\n    transforms.ToTensor(),\n    transforms.Normalize((0.5, 0.5, 0.5), (0.5, 0.5, 0.5))\n])\n\ntest_dataset = BalineseDataset(test_data, test_images_dir, transform=test_transform)\n\nbatch_size = 32\n\ntest_loader = DataLoader(test_dataset, batch_size=batch_size, shuffle=False, num_workers=0)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:09:07.448689Z","iopub.execute_input":"2025-02-08T12:09:07.448954Z","iopub.status.idle":"2025-02-08T12:09:07.464781Z","shell.execute_reply.started":"2025-02-08T12:09:07.448923Z","shell.execute_reply":"2025-02-08T12:09:07.463925Z"}},"outputs":[],"execution_count":26},{"cell_type":"code","source":"import numpy as np\n\ndef inference(encoder, decoder, test_loader, device, char_to_idx, idx_to_char, max_seq_length, test_data):\n    \"\"\"\n    Greedy decoding inference on test data that has ground-truth labels.\n    \n    Args:\n        encoder (nn.Module): Encoder CNN.\n        decoder (nn.Module): Decoder RNN with attention.\n        test_loader (DataLoader): yields (images, labels, label_lengths).\n        device (torch.device): 'cuda' or 'cpu'.\n        char_to_idx (dict): Mapping from character to index.\n        idx_to_char (dict): Mapping from index to character.\n        max_seq_length (int): Maximum decoding steps.\n        test_data (DataFrame): Reference to get filenames or additional info.\n    \n    Returns:\n        results (list of dict):\n            [\n                {\n                    \"image_filename\": str,\n                    \"predicted_caption\": str,\n                    \"ground_truth_caption\": str\n                },\n                ...\n            ]\n    \"\"\"\n    encoder.eval()\n    decoder.eval()\n    results = []\n\n    # We'll need the <EOS> token index, in case we find it in predictions\n    eos_idx = char_to_idx['<EOS>']\n\n    with torch.no_grad():\n        for batch_idx, (images, labels, label_lengths) in enumerate(test_loader):\n            # Move data to GPU if available\n            images = images.to(device, non_blocking=True)\n            labels = labels.to(device, non_blocking=True)\n            # label_lengths = label_lengths.to(device, non_blocking=True)  # Not strictly needed for greedy decode\n\n            batch_size = images.size(0)\n\n            # Encode images\n            encoder_out = encoder(images)  # [batch_size, num_pixels, encoder_dim]\n\n            # Initialize LSTM hidden/cell\n            h, c = decoder.init_hidden_state(encoder_out)\n\n            # Current input token: <SOS> for all in the batch\n            inputs = torch.full(\n                (batch_size,),\n                fill_value=char_to_idx['<SOS>'],\n                dtype=torch.long,\n                device=device\n            )\n\n            # We'll store predicted tokens at each step\n            all_preds = []\n\n            for _ in range(max_seq_length):\n                # 1) Embed the current token\n                embeddings = decoder.embedding(inputs)  # [batch_size, embed_dim]\n\n                # 2) Attention over encoder outputs\n                attention_weighted_encoding, alpha = decoder.attention(encoder_out, h)\n\n                # 3) Gating\n                gate = decoder.sigmoid(decoder.f_beta(h))\n                attention_weighted_encoding = gate * attention_weighted_encoding\n\n                # 4) LSTM step\n                h, c = decoder.decode_step(\n                    torch.cat([embeddings, attention_weighted_encoding], dim=1),\n                    (h, c)\n                )\n\n                # 5) Predict next token\n                preds = decoder.fc(decoder.dropout(h))  # [batch_size, vocab_size]\n                _, preds_idx = preds.max(dim=1)\n\n                # 6) Append predictions for each sample\n                all_preds.append(preds_idx.cpu().numpy())\n\n                # 7) Next input is the predicted token\n                inputs = preds_idx\n\n            # Convert from shape [max_seq_length, batch_size] to [batch_size, max_seq_length]\n            all_preds = np.array(all_preds).T\n\n            # For each sample in the batch\n            for i in range(batch_size):\n                pred_indices = all_preds[i]\n\n                # Stop at <EOS> if present\n                if eos_idx in pred_indices:\n                    first_eos = np.where(pred_indices == eos_idx)[0][0]\n                    pred_indices = pred_indices[:first_eos]\n\n                pred_chars = [idx_to_char.get(idx, '') for idx in pred_indices]\n                pred_str = ''.join(pred_chars)\n\n                # Reconstruct ground truth label (removing <SOS> and <EOS>)\n                label_indices = labels[i].detach().cpu().numpy()\n                label_indices = label_indices[1:]  # drop <SOS>\n                if eos_idx in label_indices:\n                    first_eos_gt = np.where(label_indices == eos_idx)[0][0]\n                    label_indices = label_indices[:first_eos_gt]\n                else:\n                    # Also remove <PAD> if any\n                    label_indices = label_indices[label_indices != char_to_idx['<PAD>']]\n\n                label_chars = [idx_to_char.get(idx, '') for idx in label_indices]\n                label_str = ''.join(label_chars)\n\n                # Grab the filename from test_data\n                global_idx = batch_idx * batch_size + i\n                image_filename = test_data.iloc[global_idx]['filename']\n\n                results.append({\n                    'image_filename': image_filename,\n                    'predicted_caption': pred_str,\n                    'ground_truth_caption': label_str\n                })\n\n    return results","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:09:07.465731Z","iopub.execute_input":"2025-02-08T12:09:07.466055Z","iopub.status.idle":"2025-02-08T12:09:07.483569Z","shell.execute_reply.started":"2025-02-08T12:09:07.466026Z","shell.execute_reply":"2025-02-08T12:09:07.482871Z"}},"outputs":[],"execution_count":27},{"cell_type":"code","source":"# Run inference on the test set\ntest_results = inference(\n    encoder=encoder,\n    decoder=decoder,\n    test_loader=test_loader,\n    device=device,\n    char_to_idx=char_to_idx,\n    idx_to_char=idx_to_char,\n    max_seq_length=max_label_length_test,  # or some other limit\n    test_data=test_data\n)\n\n# Inspect the first few results\nfor r in test_results[:5]:\n    print(\"Image:\", r['image_filename'])\n    print(\"Predicted:\", r['predicted_caption'])\n    print(\"Ground Truth:\", r['ground_truth_caption'])\n    print()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:09:07.484386Z","iopub.execute_input":"2025-02-08T12:09:07.484616Z","iopub.status.idle":"2025-02-08T12:11:08.342353Z","shell.execute_reply.started":"2025-02-08T12:09:07.484584Z","shell.execute_reply":"2025-02-08T12:11:08.341448Z"}},"outputs":[{"name":"stdout","text":"Image: test1.png\nPredicted: ,\nGround Truth: ,\n\nImage: test2.png\nPredicted: biangkang\nGround Truth: biakta\n\nImage: test3.png\nPredicted: angantah\nGround Truth: ngantah\n\nImage: test4.png\nPredicted: saringara\nGround Truth: sarira\n\nImage: test5.png\nPredicted: ya\nGround Truth: yu\n\n","output_type":"stream"}],"execution_count":28},{"cell_type":"code","source":"import editdistance\n\ndef calculate_global_cer(test_results):\n    \"\"\"\n    Computes the global CER = (sum of all edit distances) / (sum of all reference lengths).\n    test_results should be a list of dicts with:\n      {\n        'ground_truth_caption': str,\n        'predicted_caption': str,\n        ...\n      }\n    Returns:\n      A float representing the global CER.\n    \"\"\"\n    total_edit_distance = 0\n    total_reference_length = 0\n\n    for result in test_results:\n        reference  = result['ground_truth_caption']\n        hypothesis = result['predicted_caption']\n        \n        dist = editdistance.eval(reference, hypothesis)\n        total_edit_distance     += dist\n        total_reference_length  += len(reference)\n\n    if total_reference_length > 0:\n        cer = total_edit_distance / total_reference_length\n    else:\n        cer = 0.0\n\n    return cer","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:11:08.343170Z","iopub.execute_input":"2025-02-08T12:11:08.343423Z","iopub.status.idle":"2025-02-08T12:11:08.348013Z","shell.execute_reply.started":"2025-02-08T12:11:08.343403Z","shell.execute_reply":"2025-02-08T12:11:08.347181Z"}},"outputs":[],"execution_count":29},{"cell_type":"code","source":"# Compute global CER\nglobal_cer = calculate_global_cer(test_results)\nprint(f\"Global CER on Test Set: {global_cer:.4f}\")\n\n# Add per-sample CER to each entry in test_results so we can sort by it\nfor i, result in enumerate(test_results):\n    ref = result['ground_truth_caption']\n    hyp = result['predicted_caption']\n    # avoid zero-division if ref is empty\n    if len(ref) == 0:\n        sample_cer = 0.0 if len(hyp) == 0 else float('inf')\n    else:\n        sample_cer = editdistance.eval(ref, hyp) / len(ref)\n    result['cer'] = sample_cer\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-02-08T12:11:08.348697Z","iopub.execute_input":"2025-02-08T12:11:08.348948Z","iopub.status.idle":"2025-02-08T12:11:08.391340Z","shell.execute_reply.started":"2025-02-08T12:11:08.348928Z","shell.execute_reply":"2025-02-08T12:11:08.390548Z"}},"outputs":[{"name":"stdout","text":"Global CER on Test Set: 0.6518\n","output_type":"stream"}],"execution_count":30},{"cell_type":"code","source":"sorted_results = sorted(test_results, key=lambda x: x['cer'], reverse=True)\n\nN = 10\nprint(f\"\\nTop {N} samples with highest CER:\")\nfor i in range(min(N, len(sorted_results))):\n    r = sorted_results[i]\n    print(f\"Sample {i+1}:\")\n    print(f\"Image Filename: {r['image_filename']}\")\n    print(f\"CER: {r['cer']:.4f}\")\n    print(f\"Ground Truth : {r['ground_truth_caption